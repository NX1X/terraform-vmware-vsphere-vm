# Local .terraform directories
**/.terraform/*

# .tfstate files (may contain secrets - never commit)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Variable files with real values - keep only the .example
*.tfvars
*.tfvars.json
!*.tfvars.example
!terraform.tfvars.example

# Override files (used for local overrides)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Plan output files
*.tfplan
tfplan

# CLI config / credential files
.terraformrc
terraform.rc

# Sensitive info
*private*
*.pem
*.key

# VIM junk
*.un~
*.swp

# Claude Code
.claude/
CLAUDE.md
